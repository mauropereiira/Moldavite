{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Moldavite",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://**" }]
    },
    "updater:default",
    "process:allow-restart",
    "dialog:default"
  ]
}
